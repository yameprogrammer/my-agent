# =================================================================
# '소설 싸개' 프로젝트 프로덕션/로컬 환경 변수 템플릿
# 복사하여 .env 파일로 사용하시고 실제 값들을 설정하십시오.
# =================================================================

# 1. 애플리케이션 기본 설정
# - development: 개발/로컬 환경 (기본 비밀값 사용 시 경고 발생)
# - production: 프로덕션 환경 (기본 비밀값 사용 시 구동 거부 및 강력한 패스워드 정책 적용)
ENVIRONMENT=development

# 2. 데이터베이스 설정
# PostgreSQL pgvector 호환 연결 정보
# 예: postgresql+asyncpg://<username>:<password>@<host>:<port>/<db_name>
DATABASE_URL=postgresql+asyncpg://postgres:password@127.0.0.1:5432/novel_db

# 3. 인증 및 JWT 설정
# JWT_SECRET: 프로덕션 배포 시 반드시 고유하고 강력한 키로 변경하십시오.
JWT_SECRET=dev-secret-key-do-not-use-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 4. CORS 설정
# 허용할 Origin 목록을 쉼표(,) 및 JSON 배열 형태로 설정
# 예: ["http://localhost:3000", "https://yourdomain.com"]
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:8000"]

# 5. 데이터 보안 (API 키 암호화용)
# API_KEY_ENCRYPTION_SECRET: 사용자별 개별 override API Key를 데이터베이스에 안전하게 암호화 보관하기 위한 키.
# 32-byte URL-safe base64 key 생성법: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_ENCRYPTION_SECRET=

# 6. AI LLM API Keys
# AI 작가 시스템 및 RAG 구동을 위해 필요합니다.
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# 7. 외부 리서치 및 에이전트 서비스 API Keys
TAVILY_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# 8. 이메일(SMTP) 설정
# 회원가입 승인 알림 메일 발송용
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME="AI 소설 작가 시스템"

# 9. 텔레그램 승인 봇 설정
# 가입 승인 요청 및 간편 알림 발송용
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# 10. 관리자 설정
ADMIN_EMAIL=admin@example.com
BASE_URL=http://localhost:8000

# 11. 최초 배포 시 생성되는 수퍼유저 크리덴셜
# 프로덕션에서는 반드시 강력한 비밀번호로 덮어쓰십시오.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin-pass-123!
INITIAL_ADMIN_EMAIL=admin@example.com
